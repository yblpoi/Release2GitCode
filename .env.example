# Release2GitCode Docker Compose environment example

# Container / service
COMPOSE_PROJECT_NAME=release2gitcode
CONTAINER_NAME=release2gitcode
HOST=0.0.0.0
PORT=8000
PUBLISHED_PORT=8000

# Security
# Production recommends REQUIRE_HTTPS=true behind a reverse proxy that sets X-Forwarded-Proto=https
REQUIRE_HTTPS=false

# Choose one of the following:
# 1. Provide a fixed 64-character API key
#    Format: Must start with "r2gc-", followed by 59 characters containing only
#            uppercase letters, lowercase letters, digits, and hyphens (-)
#    Example: r2gc-AbC123-xYz789-...
API_KEY=
# 2. Or provide a precomputed bcrypt hash instead
API_KEY_HASH=

# Optional runtime tuning
GITHUB_API_BASE=https://api.github.com
GITHUB_DOWNLOAD_USER_AGENT=Release2GitCode/3.0 (github-release-sync)
GITCODE_API_BASE=https://api.gitcode.com/api/v5
CHUNK_SIZE=1048576
UPLOAD_ATTEMPTS=5
GITHUB_MAX_RETRIES=5
HTTP_TIMEOUT_SECONDS=30.0
HTTP_MAX_CONNECTIONS=20
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
RETRY_DELAY_SECONDS=1.0
GITHUB_BACKOFF_BASE_SECONDS=1.0
GITHUB_BACKOFF_MAX_SECONDS=60.0
SYNC_CONCURRENCY=3
SYNC_MAX_ACTIVE_TASKS=2

# Data directory on the host
DATA_DIR=./data
